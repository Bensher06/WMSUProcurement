# Copy to .env.local and fill in from Supabase: Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public site URL used in Supabase email links (confirm signup, etc.). Must match how
# users open the app and be listed under Authentication → URL Configuration → Redirect URLs.
# Examples: http://localhost:3000  https://your-app.vercel.app
# VITE_SITE_URL=http://localhost:3000
