{
  "expo": {
    "name": "WMSU Procurement",
    "slug": "wmsu-procurement",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/wmsu-logo.png",
    "scheme": "mynewproject",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.wmsu.procurement",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wmsu.procurement",
      "adaptiveIcon": {
        "backgroundColor": "#8B0000",
        "foregroundImage": "./assets/images/wmsu-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/wmsu-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#F5F5F5",
          "dark": {
            "backgroundColor": "#1A1A1A"
          }
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1c97a124-2831-40db-a3b5-37b357c69de1"
      }
    },
    "owner": "bensher"
  }
}
